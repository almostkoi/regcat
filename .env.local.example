# Regcat Environment Variables

# Port for the dev/production server (defaults to 3000)
PORT=3000

# AI Regex Generator - Optional API keys for regex generation from descriptions
# At least one key is needed to enable the generator component
# If neither key is set, the generator component will be hidden
GEMINI_API_KEY=
GROK_API_KEY=

# That's it! Regcat works with zero configuration.
# All regex explanations are generated locally.
# For AI regex generation, provide at least one API key above.

